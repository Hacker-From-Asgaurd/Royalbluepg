{
  "version": 2,
  "buildCommand": "cd royal-blue-main/client && npm install && npm run build",
  "outputDirectory": "royal-blue-main/client/dist",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ]
}
